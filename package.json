{
  "name": "controle-financeiro-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend administrativo do sistema de controle financeiro.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "quality:gate": "npm run security:audit && npm run lint && npm run build && npm run test -- --coverage --threshold.lines=80 --threshold.functions=80 --threshold.statements=80 --threshold.branches=70",
    "quality:check": "npm run lint && npm run build && npm run coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix --audit-level=moderate",
    "generate:types": "swagger-typescript-api generate -p http://localhost:5000/swagger/v1/swagger.json -o src/types/generated -n api.ts --extract-enums --modular --add-headers --clean-output"
  },
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-virtual": "^3.13.24",
    "antd": "^6.3.5",
    "axios": "^1.14.0",
    "date-fns": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.10",
    "swagger-typescript-api": "^13.6.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
