VITE_API_BASE_URL=http://localhost:5000/api/v1
# Modos: development (header X-Debug-User) | google (login Google + JWT) | jwt | disabled
# ATENCAO: 'development' e SOMENTE para maquina local (login sem verificacao via X-Debug-User).
# NUNCA use 'development' em ambientes publicados — em build de producao ele e coagido para 'google'.
VITE_AUTH_MODE=development
VITE_DEVELOPMENT_USER_HEADER=X-Debug-User
# Obrigatório quando VITE_AUTH_MODE=google (Client ID OAuth do Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=
